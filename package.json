{
  "name": "tex64",
  "version": "0.1.0",
  "description": "Electron ベースの LaTeX エディタ（開発中）。",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "electron:dev": "electron .",
    "dist:bootstrap": "node scripts/bootstrap-electron-assets.cjs",
    "dist:prep": "npm run -s dist:bootstrap && npm run -s legal:notice",
    "electron:pack": "npm run -s dist:prep && npm run -s web:build && electron-builder --dir",
    "electron:dist": "npm run -s dist:prep && npm run -s web:build && electron-builder --publish never",
    "electron:dist:mac": "npm run -s dist:prep && npm run -s web:build && electron-builder --mac --publish never",
    "web:build": "tsc -p web-src/tsconfig.json",
    "test:unit": "node --test tests/unit/*.test.mjs",
    "test:unit:with-build": "npm run -s web:build && npm run -s test:unit",
    "test:nightly": "node --test tests/unit/*.test.mjs tests/nightly/*.test.mjs",
    "test:nightly:with-build": "npm run -s web:build && npm run -s test:nightly",
    "bench:synctex:forward": "node scripts/synctex-forward-bench.cjs",
    "bench:synctex:forward:gate": "node scripts/synctex-forward-bench.cjs --strict",
    "release:artifact-hash": "node scripts/release-artifact-hash.cjs",
    "release:checksums": "node scripts/release-checksums.cjs",
    "release:update-feed": "node scripts/release-update-feed.cjs",
    "release:bundle": "node scripts/release-bundle.cjs",
    "release:mac": "node scripts/release-macos.cjs",
    "legal:notice": "node scripts/generate-third-party-notices.cjs --lock package-lock.json --out NOTICE.md --project tex64",
    "e2e:completion": "node tests/e2e/completion.e2e.mjs",
    "e2e:ai:input-send": "node tests/e2e/ai.input-send.e2e.mjs",
    "e2e:ai:attachments": "node tests/e2e/ai.attachments.e2e.mjs",
    "e2e:ai:user-authoring": "node tests/e2e/ai.real-user-authoring.e2e.mjs",
    "e2e:ai:real-api-user-function-calling": "node tests/e2e/ai.real-api-user-function-calling.e2e.mjs",
    "e2e:ai:autonomous-writing": "node tests/e2e/ai.autonomous-writing.e2e.mjs",
    "e2e:ai:functions": "node tests/e2e/ai.functions.e2e.mjs",
    "e2e:ai:copilot-workflows": "node tests/e2e/ai.copilot-workflows.e2e.mjs",
    "e2e:ai": "node tests/e2e/ai.e2e.mjs",
    "e2e:ai:full": "npm run -s e2e:ai:input-send && npm run -s e2e:ai:functions && npm run -s e2e:ai:autonomous-writing && npm run -s e2e:ai:copilot-workflows",
    "e2e:chapter13": "npm run -s e2e:ai:input-send && npm run -s e2e:ai:attachments && npm run -s e2e:ai:functions && npm run -s e2e:ai",
    "e2e:settings-runtime-env": "node tests/e2e/settings-runtime-env.e2e.mjs",
    "e2e:runtime-onboarding-build-guard": "node tests/e2e/runtime-onboarding-build-guard.e2e.mjs",
    "e2e:chapter14": "npm run -s e2e:settings-runtime-env && npm run -s e2e:build && npm run -s e2e:clean && npm run -s e2e:formatter && npm run -s e2e:viewer-ops && npm run -s e2e:synctex-controls && npm run -s e2e:math-wysiwyg-boundary",
    "e2e:persistence-surfaces": "node tests/e2e/persistence-surfaces.e2e.mjs",
    "e2e:chapter15": "npm run -s e2e:workspace-model-root && npm run -s e2e:file-tree-ops && npm run -s e2e:math-wysiwyg-boundary && npm run -s e2e:build && npm run -s e2e:launcher-workspace && npm run -s e2e:persistence-surfaces",
    "e2e:external-links-shortcuts": "node tests/e2e/external-links-shortcuts.e2e.mjs",
    "e2e:chapter16": "npm run -s e2e:external-links-shortcuts",
    "e2e:limits-constraints": "node tests/e2e/limits-constraints.e2e.mjs",
    "e2e:ghost-api-limits": "E2E_ONLY_GHOST=1 E2E_GHOST_REMOTE=1 E2E_GHOST_API_LIMITS=1 E2E_SKIP_GHOST_SETTINGS=1 E2E_SKIP_GHOST_REMOTE_SMOKE=1 E2E_SKIP_GHOST_LOCAL=1 node tests/e2e/input-assist.e2e.mjs",
    "e2e:chapter17": "npm run -s e2e:limits-constraints && npm run -s e2e:ghost-api-limits && npm run -s e2e:search && npm run -s e2e:issues && npm run -s e2e:ai:attachments && npm run -s e2e:launcher-workspace",
    "e2e:build": "node tests/e2e/build.e2e.mjs",
    "e2e:build-cancel": "node tests/e2e/build-cancel.e2e.mjs",
    "e2e:clean": "node tests/e2e/clean.e2e.mjs",
    "e2e:formatter": "node tests/e2e/formatter.e2e.mjs",
    "e2e:chapter8": "npm run -s e2e:build && npm run -s e2e:clean && npm run -s e2e:formatter",
    "e2e:math-capture": "node tests/e2e/math-capture.e2e.mjs",
    "e2e:math-wysiwyg-basic": "node tests/e2e/math-wysiwyg-basic.e2e.mjs",
    "e2e:math-wysiwyg-interactions": "node tests/e2e/math-wysiwyg-interactions.e2e.mjs",
    "e2e:math-wysiwyg-advanced": "node tests/e2e/math-wysiwyg-advanced.e2e.mjs",
    "e2e:math-wysiwyg-boundary": "node tests/e2e/math-wysiwyg-boundary-suite.e2e.mjs",
    "e2e:math-wysiwyg-specialized": "node tests/e2e/math-wysiwyg-specialized.e2e.mjs",
    "e2e:math-wysiwyg-command-fallback": "node tests/e2e/math-wysiwyg-command-fallback.e2e.mjs",
    "e2e:math-wysiwyg-spacing-commands": "node tests/e2e/math-wysiwyg-spacing-commands.e2e.mjs",
    "e2e:math-wysiwyg-catalog": "node tests/e2e/math-wysiwyg-catalog.e2e.mjs",
    "e2e:math-wysiwyg-catalog-all": "node tests/e2e/math-wysiwyg-catalog-all.e2e.mjs",
    "e2e:math-wysiwyg-insert-formats": "node tests/e2e/math-wysiwyg-insert-formats.e2e.mjs",
    "e2e:math-wysiwyg-discoverability": "node tests/e2e/math-wysiwyg-discoverability.e2e.mjs",
    "e2e:math-wysiwyg-fallback": "node tests/e2e/math-wysiwyg-fallback.e2e.mjs",
    "e2e:math-wysiwyg-famous-formulas": "node tests/e2e/math-wysiwyg-famous-formulas.e2e.mjs",
    "e2e:math-wysiwyg-famous-formulas-next50": "node tests/e2e/math-wysiwyg-famous-formulas-next50.e2e.mjs",
    "e2e:chapter11": "npm run -s e2e:math-wysiwyg-basic && npm run -s e2e:math-wysiwyg-interactions && npm run -s e2e:math-wysiwyg-advanced && npm run -s e2e:math-wysiwyg-specialized && npm run -s e2e:math-wysiwyg-catalog && npm run -s e2e:math-wysiwyg-insert-formats && npm run -s e2e:math-wysiwyg-discoverability && npm run -s e2e:math-wysiwyg-fallback && npm run -s e2e:math-wysiwyg-famous-formulas && npm run -s e2e:math-wysiwyg-famous-formulas-next50 && npm run -s e2e:math-wysiwyg-boundary",
    "e2e:launcher-workspace": "node tests/e2e/launcher-workspace.e2e.mjs",
    "e2e:workspace-model-root": "node tests/e2e/workspace-model-root.e2e.mjs",
    "e2e:file-tree-ops": "node tests/e2e/file-tree-ops.e2e.mjs",
    "e2e:editor-layout": "node tests/e2e/editor-tabs-layout.e2e.mjs",
    "test:unit:math-ocr-service": "node --test tests/unit/math-ocr-service.test.mjs",
    "e2e:math-ocr-bench": "node tests/e2e/math-ocr-benchmark.e2e.mjs",
    "e2e:chapter12": "npm run -s e2e:math-capture",
    "e2e:issues": "node tests/e2e/issues.e2e.mjs",
    "e2e:outline": "node tests/e2e/outline.e2e.mjs",
    "e2e:search": "node tests/e2e/search.e2e.mjs",
    "e2e:chapter10": "npm run -s e2e:outline && npm run -s e2e:search && npm run -s e2e:issues",
    "e2e:input-assist": "node tests/e2e/input-assist.e2e.mjs",
    "e2e:hover": "node tests/e2e/input-assist.e2e.mjs",
    "e2e:viewer-ops": "node tests/e2e/viewer-ops.e2e.mjs",
    "e2e:synctex-controls": "node tests/e2e/synctex-controls.e2e.mjs",
    "e2e:synctex-precision": "node tests/e2e/synctex-precision.e2e.mjs",
    "e2e:synctex-element-matrix": "node tests/e2e/synctex-element-matrix.e2e.mjs",
    "e2e:synctex-viewer-modes": "node tests/e2e/synctex-viewer-modes.e2e.mjs",
    "e2e:synctex-ui-element-matrix": "node tests/e2e/synctex-ui-element-matrix.e2e.mjs",
    "e2e:synctex-all": "npm run -s e2e:synctex-precision && npm run -s e2e:synctex-element-matrix && npm run -s e2e:synctex-ui-element-matrix",
    "e2e:chapter9": "npm run -s e2e:synctex-controls && npm run -s e2e:synctex-precision && npm run -s e2e:synctex-element-matrix && npm run -s e2e:synctex-viewer-modes && npm run -s e2e:synctex-ui-element-matrix",
    "e2e:hover-visual": "node tests/e2e/hover-visual.e2e.mjs",
    "e2e:hover-frame-probe": "node tests/e2e/hover-frame-probe.e2e.mjs",
    "e2e:hover-sample-all": "node tests/e2e/hover-sample-all.e2e.mjs"
  },
  "build": {
    "appId": "com.wedd.tex64",
    "productName": "TeX64",
    "icon": "Resources/icons/tex64.png",
    "protocols": [
      {
        "name": "TeX64 URL Scheme",
        "schemes": [
          "tex64"
        ]
      }
    ],
    "asarUnpack": [
      "**/*.node",
      "**/*.dll",
      "**/*.dylib",
      "**/*.so",
      "**/*.so.*",
      "Resources/math-ocr/**"
    ],
    "files": [
      "electron/**",
      "Resources/**",
      "package.json",
      "LICENSE",
      "NOTICE.md",
      "!**/tmp/**",
      "!**/tmp-tesseract/**",
      "!**/test-workspace/**",
      "!**/test-sample-hover/**",
      "!**/tests/**",
      "!**/.github/**",
      "!**/.git/**",
      "!**/.vercel/**",
      "!**/.tex64/**",
      "!**/.venv*/**",
      "!**/docs/**"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "artifactName": "${productName}-${version}-mac-${arch}.${ext}",
      "icon": "Resources/icons/tex64.icns",
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist"
    }
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^25.1.8",
    "playwright": "^1.58.2",
    "typescript": "^5.5.4"
  },
  "dependencies": {
    "mathlive": "^0.108.2",
    "node-fetch": "^2.6.7",
    "onnxruntime-node": "^1.23.2",
    "pdfjs-dist": "^4.7.76",
    "pg": "^8.18.0",
    "tesseract.js": "^5.1.1",
    "tr46": "^0.0.3",
    "webidl-conversions": "^3.0.0",
    "whatwg-url": "^5.0.0"
  }
}
