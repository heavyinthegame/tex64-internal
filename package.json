{
  "name": "tex64",
  "version": "0.1.10",
  "description": "Electron ベースの LaTeX エディタ（開発中）。",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "node scripts/dev.cjs",
    "electron:dev": "npm run -s web:build && electron .",
    "electron:dev:fast": "electron .",
    "dist:bootstrap": "node scripts/bootstrap-electron-assets.cjs",
    "dist:prep": "npm run -s dist:bootstrap && npm run -s legal:notice",
    "electron:pack": "npm run -s dist:prep && npm run -s web:build && electron-builder --dir",
    "electron:dist": "npm run -s dist:prep && npm run -s web:build && electron-builder --publish never",
    "electron:dist:mac": "npm run -s dist:prep && npm run -s web:build && electron-builder --mac --publish never",
    "dmg:background": "node scripts/generate-dmg-background.cjs",
    "math:check": "node scripts/check-math-stack.cjs",
    "mathlive:clean": "node scripts/clean-mathlive-fork.cjs",
    "mathlive:build": "node scripts/build-mathlive-fork.cjs",
    "mathlive:rebuild": "npm run -s mathlive:clean && npm run -s mathlive:build",
    "web:build": "npm run -s math:check && npm run -s mathlive:build && tsc -p web-src/tsconfig.json",
    "web:watch": "tsc -p web-src/tsconfig.json -w",
    "bench:synctex:forward": "node scripts/synctex-forward-bench.cjs",
    "bench:synctex:forward:gate": "node scripts/synctex-forward-bench.cjs --strict",
    "release:artifact-hash": "node scripts/release-artifact-hash.cjs",
    "release:checksums": "node scripts/release-checksums.cjs",
    "release:update-feed": "node scripts/release-update-feed.cjs",
    "release:bundle": "node scripts/release-bundle.cjs",
    "release:mac": "node scripts/release-macos.cjs",
    "release:upload-downloads": "node scripts/release-upload-downloads.cjs",
    "release:go-no-go": "node scripts/release-go-no-go.cjs",
    "legal:notice": "node scripts/generate-third-party-notices.cjs --lock package-lock.json --out NOTICE.md --project tex64"
  },
  "build": {
    "appId": "com.wedd.tex64",
    "productName": "TeX64",
    "icon": "Resources/icons/tex64.png",
    "protocols": [
      {
        "name": "TeX64 URL Scheme",
        "schemes": [
          "tex64"
        ]
      }
    ],
    "asarUnpack": [
      "**/*.node",
      "**/*.dll",
      "**/*.dylib",
      "**/*.so",
      "**/*.so.*",
      "Resources/math-ocr/**"
    ],
    "files": [
      "electron/**",
      "Resources/**",
      "package.json",
      "LICENSE",
      "NOTICE.md",
      "!**/tmp/**",
      "!**/tmp-tesseract/**",
      "!**/test-workspace/**",
      "!**/test-sample-hover/**",
      "!**/tests/**",
      "!**/.github/**",
      "!**/.git/**",
      "!**/.vercel/**",
      "!**/.tex64/**",
      "!**/.venv*/**",
      "!**/docs/**"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "artifactName": "${productName}-${version}-mac-${arch}.${ext}",
      "icon": "Resources/icons/tex64.icns",
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist"
    },
    "dmg": {
      "title": "${productName} ${version}",
      "background": "assets/dmg/background.png",
      "iconSize": 104,
      "iconTextSize": 12,
      "window": {
        "width": 640,
        "height": 420
      },
      "contents": [
        {
          "x": 180,
          "y": 300
        },
        {
          "x": 460,
          "y": 300,
          "type": "link",
          "path": "/Applications",
          "name": "Applications"
        }
      ]
    }
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^25.1.8",
    "playwright": "^1.58.2",
    "typescript": "^5.5.4"
  },
  "dependencies": {
    "@langchain/core": "~0.3.58",
    "@langchain/langgraph": "~0.2.74",
    "@langchain/openai": "~0.3.16",
    "diff": "^5.2.0",
    "fast-xml-parser": "^5.5.2",
    "katex": "^0.16.38",
    "langchain": "~0.3.37",
    "marked": "^17.0.4",
    "node-fetch": "^2.6.7",
    "onnxruntime-node": "^1.23.2",
    "pdfjs-dist": "^4.7.76",
    "pg": "^8.18.0",
    "tesseract.js": "^5.1.1",
    "tr46": "^0.0.3",
    "webidl-conversions": "^3.0.0",
    "whatwg-url": "^5.0.0",
    "zod": "^3.23.8"
  }
}
